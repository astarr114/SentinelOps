# SentinelOps — Environment Variables
# Copy to .env.local for local development:
#   cp .env.example .env.local
#
# Never commit .env or .env.local (they may contain secrets).

# ── Required (frontend) ──────────────────────────────────────────────────────
# From Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Optional (frontend) ──────────────────────────────────────────────────────
# Public app URL — used in alert emails and PagerDuty links

# VITE_APP_URL=https://your-app.vercel.app

# ── Supabase Edge Function secrets ───────────────────────────────────────────
# Set via: supabase secrets set KEY=value
# Or Supabase Dashboard → Edge Functions → Secrets
# These are NOT prefixed with VITE_ — they run server-side only.

# Auto-injected by Supabase when functions are deployed:
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Splunk defaults for headless / judge CI (optional — users can also configure in Settings UI)
# SPLUNK_HOST=https://your-ngrok-or-splunk-host:8089
# SPLUNK_TOKEN=your_splunk_rest_or_hec_token
# SPLUNK_MCP_URL=https://your-ngrok-host/services/mcp
# SPLUNK_MCP_TOKEN=your_splunk_mcp_bearer_token

# AI / integrations (optional — Gemini works without keys in demo; set for production)
# INTEGRATIONS_API_KEY=your_shared_integrations_key

# Webhook + alert routing (optional)
# SPLUNK_WEBHOOK_SECRET=random_secret_for_splunk_alert_webhook
# PAGERDUTY_ROUTING_KEY=
# PAGERDUTY_REST_API_KEY=
# RESEND_API_KEY=

# ── Local Splunk + ngrok (typical hackathon setup) ────────────────────────────
# 1. Run Splunk Enterprise on https://localhost:8089
# 2. Install Splunk MCP Server app
# 3. ngrok http https://localhost:8089
# 4. In SentinelOps Settings → enter ngrok base URL (e.g. https://xxxx.ngrok-free.dev)
#    SentinelOps auto-appends /services/mcp and ngrok-skip-browser-warning header.
#
# Demo login (after seed): username admin / password 12345678
# Or register any username on the login page.
